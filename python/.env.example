# BARQ Environment Configuration
# Copy this file to .env and fill in your values

# ─── Server ────────────────────────────────────────────────────────────
SIDECAR_HOST=127.0.0.1
SIDECAR_PORT=8956
BARQ_DEBUG=false

# ─── Career / Jobs ─────────────────────────────────────────────────────
CAREER_OPS_PATH=C:\Users\pc\career-ops
RESUME_PATH=
BARQ_PORT=8111

# ─── Voice ─────────────────────────────────────────────────────────────
WAKE_WORD=hey barq
VOSK_MODEL_PATH=models/vosk
WHISPER_MODEL=base

# ─── Local LLM (Ollama) ────────────────────────────────────────────────
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b

# ─── Background Scheduler ──────────────────────────────────────────────
JOB_SCAN_INTERVAL_HOURS=6
AUTO_MATCH_INTERVAL_HOURS=1

# ─── Matching Thresholds ───────────────────────────────────────────────
MATCH_THRESHOLD=0.7
MATCH_THRESHOLD_HIGH=80
MATCH_THRESHOLD_MEDIUM=60

# ─── Database ──────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///python/barq.db

# ─── Email / SMTP ──────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
NOTIFICATION_EMAIL=
SENDER_NAME=Your Name

# ─── Notifications ─────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── API Keys ──────────────────────────────────────────────────────────
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
OPENAI_API_KEY=
YOUTUBE_API_KEY=
TWITTER_API_KEY=
TWITTER_API_SECRET=
