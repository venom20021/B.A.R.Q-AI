# BARQ - Environment Variables
# Copy this file to .env and fill in your values

# --- Job Search ---
# LinkedIn credentials (optional, for enhanced scraping)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# OpenAI API key (for resume/cover letter generation fallback)
OPENAI_API_KEY=

# Ollama endpoint (local LLM)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1

# --- Social Media APIs ---
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

INSTAGRAM_ACCESS_TOKEN=

TIKTOK_ACCESS_TOKEN=

# --- Notifications ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Email ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFICATION_EMAIL=

# --- Analytics ---
# Optional: Google Analytics measurement protocol
GA_MEASUREMENT_ID=

# --- Python Sidecar ---
PYTHON_SIDECAR_PORT=8956
PYTHON_SIDECAR_HOST=127.0.0.1
