# ─── BARQ Environment Configuration ─────────────────────────────────────────
# Copy this file to .env and customize.
#   macOS/Linux:   cp .env.example .env
#   Windows:       copy .env.example .env

# ─── Server ──────────────────────────────────────────────────────────────────
BARQ_HOST=127.0.0.1
BARQ_PORT=8956
BARQ_DEBUG=false

# ─── Voice ───────────────────────────────────────────────────────────────────
WAKE_WORD=hey barq
VOSK_MODEL_PATH=models/vosk
VOSK_HINDI_MODEL_PATH=models/vosk-hi
WHISPER_MODEL=base
VOICE_LANGUAGE=en

# ─── LLM ─────────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b

# ─── Database ────────────────────────────────────────────────────────────────
# Default: sqlite+aiosqlite:///python/barq.db
# DATABASE_URL=

# ─── Career / Jobs ──────────────────────────────────────────────────────────
CAREER_OPS_PATH=~/career-ops
RESUME_PATH=
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# ─── Notifications ────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFICATION_EMAIL=

# ─── Social Media (optional) ──────────────────────────────────────────────────
# YOUTUBE_API_KEY=
# TWITTER_API_KEY=
# INSTAGRAM_ACCESS_TOKEN=

# ─── Job Scan Scheduling ─────────────────────────────────────────────────────
JOB_SCAN_INTERVAL_HOURS=6
